<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- This allows FileProvider to access the app's internal files directory -->
    <files-path name="my_internal_files" path="." />
    <!-- API < 29: export writes to shared public Documents; FileProvider needs this to share it -->
    <external-path name="public_documents" path="Documents/" />

    <!-- App-private external storage for camera/video captures (external-files-path
         resolves to getExternalFilesDir() automatically, no app ID hardcoding needed) -->
    <external-files-path name="my_images" path="Pictures/" />
    <external-files-path name="my_videos" path="Movies/" />
    <external-files-path name="my_audio" path="Music/" />
</paths>
