<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/sub_question_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/sub_answers_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/sub_remarks_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Remarks..."
        android:inputType="textMultiLine"
        android:minLines="1"
        android:maxLines="3"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/sub_attach_file_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/ic_attach_file"
            android:contentDescription="Attach File" />

        <ImageButton
            android:id="@+id/sub_add_photo_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/ic_add_a_photo"
            android:contentDescription="Add Photo" />

        <ImageButton
            android:id="@+id/sub_add_video_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/ic_add_video"
            android:contentDescription="Add Video" />

        <ImageButton
            android:id="@+id/sub_add_audio_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/ic_add_audio"
            android:contentDescription="Add Audio" />

        <ImageButton
            android:id="@+id/sub_add_sketch_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/ic_map"
            android:contentDescription="Draw on Map" />

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/sub_attachments_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp" />

    </HorizontalScrollView>

</LinearLayout>
